{
	"compilerOptions": {
		"lib": ["es2022"],

		/* Base Options */
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2022",
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"isolatedModules": true,

		/* Strictness */
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		/* For transpiling with TypeScript: */
		"module": "NodeNext",
		"rootDir": "src",
		"outDir": "dist",
		"sourceMap": true
	}
}
